{
  "name": "frontier-map-renderer",
  "private": true,
  "workspaces": [
    "renderer",
    "ui"
  ],
  "scripts": {
    "build": "npm run --workspaces --if-present build",
    "clean": "npm run --workspaces --if-present clean",
    "dev": "concurrently --kill-others \"npm:dev:*\"",
    "dev:renderer": "npm run dev --silent --workspace=renderer",
    "dev:ui": "npm run dev --silent --workspace=ui"
  },
  "devDependencies": {
    "@rollup/plugin-terser": "^0.4.4",
    "@rollup/plugin-typescript": "^12.1.2",
    "@types/node": "^22.15.27",
    "concurrently": "^9.2.1",
    "cross-env": "^7.0.3",
    "rimraf": "^6.1.0",
    "rollup": "^4.43.0",
    "rollup-plugin-string-import": "^1.2.6",
    "tslib": "^2.8.1",
    "typescript": "^5.8.3"
  }
}
